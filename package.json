{
  "name": "express-light-rail",
  "version": "0.3.0",
  "description": "Rails-inspired controller, policy, and service primitives for Express applications.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "src/**/*.md"
  ],
  "scripts": {
    "clean": "rm -rf ./dist",
    "build": "npm run clean && vite build",
    "test": "vitest",
    "prepublishOnly": "npm run check-types && npm run test -- --run && npm run build",
    "ts-node": "ts-node -r tsconfig-paths/register --logError",
    "lint": "eslint .",
    "check-types": "tsc -p tests/tsconfig.json --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/klondikemarlen/express-light-rail.git"
  },
  "keywords": [
    "express",
    "controller",
    "model",
    "service",
    "rails"
  ],
  "author": "Marlen Brunner",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "peerDependencies": {
    "@sequelize/core": "^7.0.0-alpha.43",
    "express": "^4.21.2"
  },
  "dependencies": {
    "lodash": "^4.17.21",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@sequelize/core": "^7.0.0-alpha.43",
    "@types/express": "^4.17.21",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.20.1",
    "eslint-config-prettier": "^10.0.1",
    "express": "^4.21.2",
    "supertest": "^7.0.0",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.10",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.24.0",
    "vite": "^5.4.21",
    "vite-plugin-dts": "^4.5.4",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^2.1.8"
  }
}
